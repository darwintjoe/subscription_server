ALLOW_DEV_AUTH=false

# Optional payment provider secrets for future real integrations.
XENDIT_API_KEY=
STRIPE_SECRET_KEY=
PAYMENT_WEBHOOK_SECRET=

# Optional Google Sheet backup webhook endpoint.
GOOGLE_SHEET_SCRIPT_URL=
